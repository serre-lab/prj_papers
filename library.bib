@article{ding2025a,
  title = {{Functional connectomics reveals general wiring rule in mouse visual cortex}},
  author = {Ding, Zhuokun and Fahey, Paul G. and Papadopoulos, S. and Wang, Eric Y. and Celii, Brendan},
  year = {2025},
  doi = {10.1038/s41586-025-08840-3},
  abstract = {Understanding the relationship between circuit connectivity and function is crucial for uncovering how the brain computes. In mouse primary visual cortex, excitatory neurons with similar response properties are more likely to be synaptically connected; however, broader connectivity rules remain unknown. Here we leverage the millimetre-scale MICrONS dataset to analyse synaptic connectivity and functional properties of neurons across cortical layers and areas.}
}

